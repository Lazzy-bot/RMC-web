# Copy this file to .env and fill real values before `docker compose up -d`

# Flask session key (must be random, keep secret)
APP_SECRET_KEY=replace-with-random-secret
PUBLIC_BASE_URL=
CLOUDFLARE_TUNNEL_TOKEN=

# Hard admin account(s), comma separated
ADMIN_EMAILS=dung.ho@aeondelight.biz

# Microsoft OAuth app (Azure App Registration)
MS_OAUTH_CLIENT_ID=
MS_OAUTH_CLIENT_SECRET=
# Optional: force tenant-specific endpoint (recommended for single-tenant app)
MS_OAUTH_TENANT_ID=

# Google OAuth app
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=


# ============================================================
# Rate Limiting Configuration
# Bỏ comment và thay giá trị để tùy chỉnh. Mặc định đã được tối ưu.
# Đặt RATE_LIMIT_ENABLED=false để tắt hoàn toàn (VD: khi debug local).
# ============================================================

# Bật/tắt toàn bộ rate limiting (default: true)
# RATE_LIMIT_ENABLED=true

# --- Login / Brute-force protection (per IP) ---
# 5 lần thử login trong 60s, bị block 5 phút nếu vượt
# RATE_LIMIT_LOGIN_MAX=5
# RATE_LIMIT_LOGIN_PERIOD=60
# RATE_LIMIT_LOGIN_BLOCK=300

# --- General API limit (per IP) ---
# 100 request/60s, block 60s nếu vượt
# RATE_LIMIT_API_MAX=100
# RATE_LIMIT_API_PERIOD=60
# RATE_LIMIT_API_BLOCK=60

# --- General API limit (per authenticated user) ---
# 200 request/60s (cao hơn per-IP vì 1 IP có thể có nhiều user)
# RATE_LIMIT_USER_MAX=200

# --- Heavy/expensive endpoints (charts, dashboard, report, sync) ---
# 10 request/60s, block 2 phút nếu vượt
# RATE_LIMIT_HEAVY_MAX=10
# RATE_LIMIT_HEAVY_PERIOD=60
# RATE_LIMIT_HEAVY_BLOCK=120


# --- OneDrive sync trigger (per IP) — rất tốn kém! ---
# 3 lần sync trong 5 phút, block 10 phút nếu vượt
# RATE_LIMIT_SYNC_MAX=3
# RATE_LIMIT_SYNC_PERIOD=300
# RATE_LIMIT_SYNC_BLOCK=600

# --- Admin endpoints (per IP) ---
# 30 request/60s, block 2 phút nếu vượt
# RATE_LIMIT_ADMIN_MAX=30
# RATE_LIMIT_ADMIN_PERIOD=60
# RATE_LIMIT_ADMIN_BLOCK=120

# ============================================================
# SMTP Configuration for Email Reminders (Outlook/Office 365)
# ============================================================
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your_email@aeondelight.biz
SMTP_PASSWORD=your_email_password_or_app_password
SMTP_SENDER=your_email@aeondelight.biz
SMTP_SECURE=tls

