# Copy this file to .env and fill real values before `docker compose up -d`

# Flask session key (must be random, keep secret)
APP_SECRET_KEY=replace-with-random-secret
PUBLIC_BASE_URL=

# Hard admin account(s), comma separated
ADMIN_EMAILS=dung.ho@aeondelight.biz

# Microsoft OAuth app (Azure App Registration)
MS_OAUTH_CLIENT_ID=
MS_OAUTH_CLIENT_SECRET=
# Optional: force tenant-specific endpoint (recommended for single-tenant app)
MS_OAUTH_TENANT_ID=

# Google OAuth app
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Slack Incoming Webhooks
# vào trang này để kiếm URL: https://api.slack.com/apps
# DEFAULT -> #all-rmc-assistant
SLACK_WEBHOOK_DEFAULT=https://hooks.slack.com/services/XXXXXXXXX/XXXXXXXXX/XXXXXXXXXXXXXXXXXXXX
# ABDNC -> #aeon-binh-duong-new-city
SLACK_WEBHOOK_ABDNC=https://hooks.slack.com/services/XXXXXXXXX/XXXXXXXXX/XXXXXXXXXXXXXXXXXXXX
# AMDR -> #aeon-midori
SLACK_WEBHOOK_AMDR=https://hooks.slack.com/services/XXXXXXXXX/XXXXXXXXX/XXXXXXXXXXXXXXXXXXXX
# ANVL -> #aeon-nguyen-van-linh
SLACK_WEBHOOK_ANVL=https://hooks.slack.com/services/XXXXXXXXX/XXXXXXXXX/XXXXXXXXXXXXXXXXXXXX
# ATQB -> #aeon-ta-quang-buu
SLACK_WEBHOOK_ATQB=https://hooks.slack.com/services/XXXXXXXXX/XXXXXXXXX/XXXXXXXXXXXXXXXXXXXX
# AVG -> #aeon-van-giang
SLACK_WEBHOOK_AVG=https://hooks.slack.com/services/XXXXXXXXX/XXXXXXXXX/XXXXXXXXXXXXXXXXXXXX

